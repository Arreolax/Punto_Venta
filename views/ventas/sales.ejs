<!-- Pantalla de carga -->
<%- include('../partials/loadingScreen', { loaderText: 'Cargando Ventas...' }) %>

    <div id="contenido" class="hidden">
        <div class="px-5">
            <div class="p-6 space-y-4 border-4 border-black/20  rounded bg-white">

                <h1 class="font-bold text-center text-xl uppercase flex items-center justify-center gap-2">
                    Registro de Ventas
                </h1>

                <!-- Formulario de busqueda -->
                <div class="bg-white p-5 rounded-xl shadow-sm border border-gray-300">
                    <form method="GET" action="/ventas" class="space-y-5">

                        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
                            <h2 class="text-base font-semibold text-gray-700 flex items-center gap-2">
                                Búsqueda
                            </h2>

                            <div class="flex gap-2">
                                <button type="submit"
                                    class="px-4 py-2 bg-orange-500 hover:bg-orange-600 text-white rounded-md text-sm transition">
                                    Filtrar
                                </button>

                                <a href="/ventas"
                                    class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-black rounded-md text-sm transition">
                                    Limpiar Filtros
                                </a>
                            </div>
                        </div>

                        <!-- Fechas -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <input name="fechaInicio" type="date"
                                value="<%= typeof fechaInicio !== 'undefined' ? fechaInicio : '' %>"
                                class="calendar-orange w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:ring-2 focus:ring-orange-400 focus:outline-none"
                                placeholder="Fecha inicial" />

                            <input name="fechaFin" type="date"
                                value="<%= typeof fechaFin !== 'undefined' ? fechaFin : '' %>"
                                class="calendar-orange w-full border border-gray-400 rounded-md px-3 py-2 text-sm focus:ring-2 focus:ring-orange-400 focus:outline-none"
                                placeholder="Fecha final" />
                        </div>

                        <div class="my-5 border-t border-gray-400"></div>

                        <div class="flex flex-col md:flex-row gap-3 md:items-end">

                            <!-- Buscador -->
                            <div class="flex-1">
                                <div class="relative">
                                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gary-400">
                                        <i class="fa-solid fa-magnifying-glass text-gray-600"></i>
                                    </span>
                                    <input id="saleSearch" name="search"
                                        value="<%= typeof search !== 'undefined' ? search : '' %>"
                                        placeholder="Buscar por Folio o Cliente..."
                                        class="w-full pl-9 pr-3 py-2 border border-gray-400 rounded-md text-sm focus:ring-2 focus:ring-orange-400 focus:outline-none" />
                                </div>
                            </div>

                            <!-- Filtro por Metodo -->
                            <select name="metodo"
                                class="px-3 py-2 border border-gray-400 rounded-md text-sm focus:ring-2 focus:ring-orange-400 focus:outline-none">
                                <option value="Todos" <%=metodo==='Todos' ? 'selected' : '' %>>Todo</option>
                                <option value="Efectivo" <%=metodo==='Efectivo' ? 'selected' : '' %>>Efectivo
                                </option>
                                <option value="Transferencia" <%=metodo==='Transferencia' ? 'selected' : '' %>
                                    >Transferencia</option>
                            </select>

                        </div>

                    </form>
                </div>

                <% if (sales && sales.length> 0) { %>
                    <div id="salesContainer" class="max-w-full mx-auto mt-6">
                        <% sales.forEach((sale)=> { %>
                            <div class="mb-5 bg-white shadow-xl rounded-xl border border-gray-800 overflow-hidden">

                                <div
                                    class="sale-card-header cursor-pointer p-5 flex justify-between items-center hover:bg-gray-50 transition">

                                    <div class="grid grid-cols-6 gap-6 w-full text-sm">

                                        <div>
                                            <p class="text-gray-500 text-xs">Fecha de Creacion</p>
                                            <p class="font-semibold text-gray-800">
                                                <%= sale.created_at %>
                                            </p>
                                        </div>

                                        <div>
                                            <p class="text-gray-500 text-xs">Folio de Compra</p>
                                            <p class="font-semibold text-gray-800">
                                                <%= sale.folio_venta %>
                                            </p>
                                        </div>

                                        <div>
                                            <p class="text-gray-500 text-xs">Nombre del Vendedor</p>
                                            <p class="font-semibold text-gray-800">
                                                <%= sale.nombre_empleado %>
                                            </p>
                                        </div>

                                        <div>
                                            <p class="text-gray-500 text-xs">Nombre del Cliente</p>
                                            <p class="font-semibold text-gray-800">
                                                <%= sale.nombre_cliente %>
                                            </p>
                                        </div>

                                        <div>
                                            <p class="text-gray-500 text-xs">Metodo de Pago</p>
                                            <span
                                                class="px-2 py-1 text-xs rounded-full bg-green-100 text-green-700 font-medium">
                                                <%= sale.metodo_pago.charAt(0).toUpperCase() +
                                                    sale.metodo_pago.slice(1).toLowerCase() %>
                                            </span>
                                        </div>

                                        <div class="text-right">
                                            <p class="text-gray-500 text-xs">Total de Compra</p>
                                            <p class="italic font-bold text-lg text-gray-900">
                                                $<%= sale.total_pago %>
                                            </p>
                                        </div>

                                    </div>

                                    <svg class="w-5 h-5 ml-4 transition-transform duration-300 text-gray-500"
                                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M19 9l-7 7-7-7" />
                                    </svg>
                                </div>

                                <!-- Contenido Extra -->
                                <div class="hidden px-6 pb-6 border-t border-gray-100 bg-gray-50">

                                    <div class="mt-4 space-y-2 text-sm text-gray-700">
                                        <p class="font-semibold text-gray-800 mb-2">Productos:</p>

                                        <% sale.productos.forEach(producto=> { %>
                                            <div class="flex justify-between">
                                                <span>
                                                    » <%= producto.producto_nombre %>
                                                </span>
                                                <span class="text-gray-500">
                                                    <%= producto.cantidad %> unidades -
                                                        <span class="font-bold">
                                                            $<%= producto.subtotal %>
                                                        </span>
                                                </span>
                                            </div>
                                            <% }) %>
                                    </div>

                                    <div class="flex justify-end gap-3 mt-6">
                                        <% if(sale.folio_ticket==="SIN TICKET" ) { %>
                                            <a href="/tickets/generate/<%= sale.id %>"
                                                class="mt-4 px-4 py-2 bg-[#FF2A00] text-white rounded-lg hover:bg-[#FF2A00]/80 inline-block text-center">
                                                Generar Ticket
                                            </a>

                                            <% }else{ %>
                                                <% if (sale.id_factura == null) { %>
                                                    <a title="Generar Factura" href="/facturas/nueva/<%= sale.folio_venta %>"
                                                        class="mt-4 px-4 py-2 bg-[#FF5100] hover:bg-[#902d00] text-white rounded-lg shadow transition">
                                                        Generar Factura
                                                    </a>
                                                    <% } else { %>
                                                        <a title="Ver Factura" href="/facturas/resumen/<%= sale.id_factura %>"
                                                            class="mt-4 px-4 py-2 bg-[#FF5100] hover:bg-[#902d00] text-white rounded-lg shadow transition">
                                                            Ver Factura
                                                        </a>
                                                        <% } %>

                                                            <a href="/tickets/vista-previa/<%= sale.folio_ticket %>"
                                                                class="mt-4 px-4 py-2 bg-[#FF2A00] text-white rounded-lg hover:bg-[#FF2A00]/80 inline-block text-center">
                                                                Ver Ticket
                                                            </a>

                                                            <% } %>

                                                                <a title="Ver Venta"
                                                                    href="/ventas/vista-previa/<%= sale.id %>"
                                                                    class="mt-4 bg-green-500 hover:bg-green-600 text-white px-4 py-2 rounded-lg shadow transition">
                                                                    Vista Detallada
                                                                </a>
                                    </div>

                                </div>
                            </div>
                            <% }) %>
                    </div>
                    <% } else { %>
                        <div class="bg-white border-0 border-white rounded-xl  p-10 text-center max-w-md mx-auto">

                            <div class="flex justify-center mb-4">
                                <div class="bg-white p-5 rounded-full">
                                    <i class="fa-solid fa-cart-shopping text-3xl text-gray-800"></i>
                                </div>
                            </div>

                            <h2 class="text-lg font-semibold text-gray-800">
                                Sin Resultados
                            </h2>

                            <p class="text-gray-500 mt-2">
                                No Se Encontraron Ventas Registradas.
                            </p>

                        </div>
                        <% } %>
            </div>
        </div>
    </div>

    <div class=" text-white px-3 py-1 rounded text-sm hidden"></div>

    <!-- Alert Modal -->
    <%- include('../partials/alertModal') %>

        <script src="/js/sales.js"></script>