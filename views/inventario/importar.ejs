<style>
  #inventario-import-view form input:not([type="checkbox"]):not([type="radio"]):focus,
  #inventario-import-view form select:focus,
  #inventario-import-view form textarea:focus {
    outline: none;
    border-color: #FF5100 !important;
    box-shadow: 0 0 0 3px rgba(255, 81, 0, 0.18);
  }

  #inventario-import-view form button:focus-visible,
  #inventario-import-view form a:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px rgba(255, 81, 0, 0.2);
  }
</style>

<div id="inventario-import-view" class="flex flex-col gap-4">
  <%- include('../partials/alertModal') %>
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Importar CSV</h1>
      <p class="text-sm text-gray-500">Agrega un archivo CSV con columnas:
        sku,name,description,category,price,cost,minStock,stock,status (En venta / Pausado).</p>
    </div>


<form id="importCsvForm" method="POST" action="/inventario/importar"
  class="bg-white border border-gray-200 rounded-2xl p-6 shadow-sm flex flex-col gap-5 max-w-2xl">

  <div
    class="border-2 border-dashed border-gray-300 rounded-2xl p-8 flex flex-col items-center justify-center text-center hover:border-gray-500 transition">

    <img
      src="/images/exel.png"
      alt="Excel"
      class="w-12 h-12 object-contain">

    <h3 class="text-base font-semibold text-gray-800">
      Selecciona un archivo
    </h3>

    <p class="text-sm text-gray-500 mt-1 mb-4">
      Compatible con archivos .xlsx, .xls y .csv
    </p>

    <input id="csvFileInput" type="file" accept=".xlsx,.xls,text/csv" class="hidden" />

    <label for="csvFileInput"
      class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-900 text-white rounded-lg text-sm font-semibold hover:bg-black cursor-pointer transition">
      
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none"
        viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
          d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1M12 4v12m0 0l-4-4m4 4l4-4" />
      </svg>

      Seleccionar archivo
    </label>

    <input type="hidden" name="csvHiddenInput" id="csvHiddenInput" />

    <p id="csvFileName" class="text-xs text-gray-500 mt-4">
      Ningún archivo seleccionado.
    </p>
  </div>

  <div
    class="flex items-center justify-between border border-gray-200 rounded-xl p-4 bg-gray-50">

    <div class="flex items-center gap-3">
      <img
        src="/images/exel.png"
        alt="Excel"
        class="w-12 h-12 object-contain">

      <div>
        <p class="text-sm font-semibold text-gray-800">
          Plantilla de ejemplo
        </p>

        <p class="text-xs text-gray-500">
          Descarga el formato correcto para importar productos.
        </p>
      </div>
    </div>

    <a href="/templates/plantilla.xlsx" download
      class="px-4 py-2 border border-gray-300 rounded-lg text-sm font-semibold text-gray-700 hover:bg-gray-100 transition">
      Descargar
    </a>
  </div>

  <div class="flex flex-wrap gap-3">
    <button type="submit"
      class="px-5 py-2.5 bg-gray-900 text-white rounded-lg text-sm font-semibold hover:bg-black transition">
      Agregar archivo
    </button>

    <a href="/inventario"
      class="px-5 py-2.5 border border-gray-300 rounded-lg text-sm font-semibold text-gray-700 hover:bg-gray-100 transition">
      Cancelar
    </a>
  </div>
</form>








    <script src="https://cdn.jsdelivr.net/npm/xlsx/dist/xlsx.full.min.js"></script>

    <script>
      document.addEventListener('DOMContentLoaded', () => {

        const form = document.getElementById('importCsvForm');
        const fileInput = document.getElementById('csvFileInput');
        const hiddenInput = document.getElementById('csvHiddenInput');
        const fileName = document.getElementById('csvFileName');

        if (!form || !fileInput || !hiddenInput || !fileName) return;

        fileInput.addEventListener('change', () => {

          if (fileInput.files.length > 0) {
            fileName.textContent = fileInput.files[0].name;
          } else {
            fileName.textContent = 'Ningún archivo seleccionado.';
          }

        });

        form.addEventListener('submit', (event) => {

          event.preventDefault();

          const selected = fileInput.files[0];

          if (!selected) {

            if (window.mostrarAlerta) {
              window.mostrarAlerta('error', 'Selecciona un archivo.');
            } else {
              alert('Selecciona un archivo.');
            }

            return;
          }

          const reader = new FileReader();

          reader.onload = (e) => {

            const data = new Uint8Array(e.target.result);

            const workbook = XLSX.read(data, { type: 'array' });

            const firstSheet = workbook.Sheets[workbook.SheetNames[0]];

            const jsonData = XLSX.utils.sheet_to_json(firstSheet);

            hiddenInput.value = JSON.stringify(jsonData);

            form.submit();

          };

          reader.onerror = () => {

            if (window.mostrarAlerta) {
              window.mostrarAlerta('error', 'No se pudo leer el archivo.');
            } else {
              alert('No se pudo leer el archivo.');
            }

          };

          reader.readAsArrayBuffer(selected);

        });

      });
    </script>


    <% if (messages && messages.error) { %>
      <script>
        document.addEventListener('DOMContentLoaded', () => {
          if (window.mostrarAlerta) window.mostrarAlerta('error', <% - JSON.stringify(messages.error) %>);
        });
      </script>
      <% } %>
        <% if (messages && messages.success) { %>
          <script>
            document.addEventListener('DOMContentLoaded', () => {
              if (window.mostrarAlerta) window.mostrarAlerta('success', <% - JSON.stringify(messages.success) %>);
            });
          </script>
          <% } %>