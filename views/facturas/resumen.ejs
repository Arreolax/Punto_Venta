<%- include('../partials/loadingScreen', { loaderText: 'Cargando Resumen...' }) %>
  <%- include('../partials/alertModal') %>

    <div id="contenido" class="hidden">
      <div class="flex flex-col gap-6">

        <!-- Encabezado -->
        <div class="flex flex-col gap-1 md:flex-row md:items-center md:justify-between">

          <div>
            <h1 class="text-2xl md:text-3xl font-bold text-gray-900">
              Resumen de Factura
            </h1>
          </div>

          <% if (factura.status_factura==='borrador' ) { %>
            <div class="flex gap-2 self-start md:self-auto">
              <a href="/facturas/nueva/<%= factura.folio_venta %>" id="btnEditar"
                class="flex items-center gap-2 px-4 py-2 border border-gray-300 rounded-md text-sm font-semibold text-gray-700 hover:bg-gray-50 ">
                <i class="fa-solid fa-pen text-xs"></i>
                Editar
              </a>

              <button data-id-factura="<%= factura.id_factura %>"
                class="btnEliminar flex items-center gap-2 px-4 py-2 border border-gray-300 rounded-md text-sm font-semibold text-gray-700 hover:bg-gray-50">
                <i class="fa-solid fa-trash-can text-xs"></i>
                Eliminar
              </button>

              <button id="btnTimbrar"
                class="btnTimbrar flex items-center gap-2 px-4 py-2 bg-[#FF5100] text-white rounded-md text-sm font-semibold hover:bg-[#d94400]">
                <i class="fa-solid fa-bolt text-xs"></i>
                <span id="btnTextT">
                    Timbrar
                  </span>
              </button>
            </div>
            <% } else if (factura.status_factura==='timbrada' ) { %>
              <div class="flex gap-2 self-start md:self-auto">
                <button data-id-factura="<%= factura.id_factura %>" id="btnCancelar"
                  class="btnCancelar flex items-center gap-2 px-4 py-2 bg-[#FF5100] text-white rounded-md text-sm font-semibold hover:bg-[#d94400]">
                  <i class="fa-solid fa-ban text-xs"></i>
                  <span id="btnTextC">
                    Cancelar
                  </span>
                </button>
              </div>
              <% } %>

        </div>

        <% if (factura.status_factura==='borrador' ) { %>
          <div class="bg-yellow-100 text-yellow-800 p-2 rounded text-base text-center">
            <span class="font-bold text-xl">-- Factura Pendiente de Timbrar --</span>
            <br>
            La Factura de Esta Venta se Encuentra en Estado Borrador. Puedes Modificarla o Timbrarla Posteriormente.
          </div>
          <% } %>

          <% if (factura.status_factura==='cancelada' ) { %>
          <div class="bg-red-100 text-yellow-800 p-2 rounded text-base text-center">
            <span class="font-bold text-xl">-- Factura Cancelada --</span>
            <br>
            La Factura de Esta Venta fue Cancelada. Contacta a un Administrador para mas Informacion.
          </div>
          <% } %>

            <!-- Contenido principal -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

              <!-- Columna izquierda: info factura -->
              <div class="lg:col-span-2 flex flex-col gap-4">
                <!-- Informacion del cliente -->
                <div class="bg-white border border-gray-400 rounded-lg p-5">
                  <div class="flex items-start justify-between mb-3">
                    <p class="text-xs font-bold uppercase tracking-wide">Informacion del Cliente</p>
                    <div class="text-right text-xs text-gray-500">
                      <p>Folio: <span class="font-bold text-gray-800" id="ticketFolio">
                          <%= factura.folio_venta %>
                        </span></p>
                      <p>Fecha: <span class="font-bold text-gray-800">
                          <%= factura.fecha_factura %>
                        </span></p>
                    </div>
                  </div>

                  <p class="text-lg font-bold text-gray-900">
                    <%= factura.cliente_nombre %>
                  </p>
                  <p id="clienteId" class="hidden">
                    <%= factura.cliente_id %>
                  </p>

                  <p class="text-sm text-gray-600 mt-0.5">RFC: <span class="font-semibold">
                      <%= factura.cliente_rfc %>
                    </span></p>
                  <p class="text-sm text-gray-500 mt-1">Regimen Fiscal: <span id="regimen" class="font-semibold">
                    </span> </p>
                  <p id="RRegimen" class="hidden">
                    <%= factura.cliente_regimen %>
                  </p>
                  <p class="text-sm text-gray-500 mt-0.5">Codigo Postal: <span class="font-semibold">
                      <%= factura.cliente_codigoPostal %>
                    </span></p>
                </div>

                <!-- Detalle de Productos -->
                <div class="bg-white border border-gray-400 rounded-lg p-5">
                  <p class="text-xs font-bold uppercase tracking-wide mb-3">Detalle de Productos</p>
                  <div class="overflow-x-auto">
                    <table class="min-w-full text-sm">
                      <thead>
                        <tr class="border-b border-gray-100">
                          <th class="text-left py-2 text-xs text-gray-500 font-semibold">Clave SAT</th>
                          <th class="text-left py-2 text-xs text-gray-500 font-semibold">Descripción</th>
                          <th class=" py-2 text-xs text-gray-500 font-semibold">Cantidad</th>
                          <th class=" py-2 text-xs text-gray-500 font-semibold">Unidad</th>
                          <th class=" py-2 text-xs text-gray-500 font-semibold">Unitario</th>
                          <th class=" py-2 text-xs text-gray-500 font-semibold">Importe</th>
                        </tr>
                      </thead>
                      <tbody class="divide-y divide-gray-50 text-center">

                        <% factura.conceptos.forEach(c=> { %>
                          <tr class="hover:bg-gray-100">
                            <td class="hidden concepto-id">
                              <%= c.id_producto %>
                            </td>

                            <td class="text-left py-2 clave-sat">
                              <%= c.sat_clave_producto || 'Clave sin Registrar' %>
                            </td>

                            <td class="text-left py-2">
                              <%= c.nombre_producto %>
                            </td>

                            <td class="">
                              <%= c.cantidad_producto %>
                            </td>

                            <td class="">
                              <%= c.sat_unidad_descripcion %>
                            </td>

                            <td class="">
                              <%= c.precio_unitario %>
                            </td>

                            <td class="">
                              <%= c.importe %>
                            </td>

                            <% }) %>

                      </tbody>
                    </table>
                  </div>
                </div>

                <% if (factura.status_factura !== 'borrador' ) { %>
                  <!-- Archivos Generados -->
                  <div class="bg-white border border-gray-400 rounded-lg p-5">
                    <p class="text-xs font-bold uppercase tracking-wide mb-4 flex items-center gap-2">
                      Archivos Generados
                    </p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

                      <!-- Tarjeta PDF -->
                      <div class="flex items-center justify-between border border-gray-300 rounded-lg p-3">
                        <div class="flex items-center gap-3">
                          <div class="h-9 w-9 rounded-lg bg-red-100 flex items-center justify-center shrink-0">
                            <i class="fa-regular fa-file-pdf text-red-600"></i>
                          </div>
                          <div>
                            <p class="text-sm font-semibold text-gray-800">Archivo PDF</p>
                            <p class="text-xs text-gray-400">Representacion impresa (Pre-visualizacion)</p>
                          </div>
                        </div>
                        <button data-id="<%= factura.id_factura %>" data-formato="pdf" data-uuid="<%= factura.uuid_facturama %>"
                          class="btn-descargar flex items-center gap-1 text-xs font-semibold text-gray-600 hover:text-[#FF5100]">
                          <i class="fa-solid fa-download text-xs"></i>
                          Descargar
                        </button>
                      </div>

                      <!-- Tarjeta XML -->
                      <div class="flex items-center justify-between border border-gray-300 rounded-lg p-3">
                        <div class="flex items-center gap-3">
                          <div class="h-9 w-9 rounded-lg bg-blue-100 flex items-center justify-center shrink-0">
                            <i class="fa-solid fa-code text-blue-600"></i>
                          </div>
                          <div>
                            <p class="text-sm font-semibold text-gray-800">Archivo XML</p>
                            <p class="text-xs text-gray-400">Valido fiscal (Pendiente de timbrado)</p>
                          </div>
                        </div>
                        <button data-id="<%= factura.id_factura %>" data-formato="xml" data-uuid="<%= factura.uuid_facturama %>"
                          class="btn-descargar flex items-center gap-1 text-xs font-semibold text-gray-600 hover:text-[#FF5100]">
                          <i class="fa-solid fa-download text-xs"></i>
                          Descargar
                        </button>
                      </div>

                    </div>
                  </div>
                  <% } %>

              </div>

              <!-- Totales y pago -->
              <div class="flex flex-col gap-4">

                <!-- Total de Factura -->
                <div class="bg-white border border-gray-400 rounded-lg p-5">
                  <p class="text-xs font-bold uppercase tracking-wide mb-4">Total de Factura</p>
                  <div class="flex flex-col gap-3 text-sm">
                    <div class="flex justify-between">
                      <span class="text-gray-600">Subtotal</span>
                      <span class="font-semibold text-gray-800">$<%= factura.subtotal_factura %></span>
                    </div>
                    <div class="flex justify-between">
                      <span class="text-gray-600">IVA (16%)</span>
                      <span class="font-semibold text-gray-800">$<%= factura.iva_factura %></span>
                    </div>
                    <div class="border-t pt-3 flex justify-between items-center">
                      <span class="text-sm font-bold text-gray-500">Total (<span id="moneda">
                          <%= factura.moneda %>
                        </span>)</span>
                      <span class="text-2xl font-bold text-[#FF5100]">$<%= factura.total_factura %></span>
                    </div>
                  </div>
                </div>

                <!-- Datos de Facturacion -->
                <div class="bg-white border border-gray-400 rounded-lg p-5">
                  <p class="text-xs font-bold uppercase tracking-wide mb-4">Datos de Facturacion</p>
                  <div class="flex flex-col gap-3 text-sm">

                    <div>
                      <p class="text-xs text-gray-400">Tipo de Comprobante</p>
                      <p id="tipo_comprobante" class="hidden">
                        <%= factura.tipo_recibo %>
                      </p>
                      <p class="font-semibold text-gray-800 mt-0.5">
                        <% if (factura.tipo_recibo==="I" ) { %>
                          I - Ingreso
                          <% } else if (factura.tipo_recibo==="E" ) { %>
                            E - Egreso
                            <% } else if (factura.tipo_recibo==="T" ) { %>
                              T - Traslado
                              <% } else if (factura.tipo_recibo==="P" ) { %>
                                P - Pago
                                <% } else { %>
                                  Sin definir
                                  <% } %>
                      </p>
                    </div>

                    <div>
                      <p class="text-xs text-gray-400">Metodo de Pago</p>
                      <p id="metodo_pago" class="hidden">
                        <%= factura.metodo_recibo %>
                      </p>
                      <p class="font-semibold text-gray-800 mt-0.5">
                        <% if (factura.metodo_recibo==="PUE" ) { %>
                          PUE - Pago en una sola exhibición
                          <% } else if (factura.metodo_recibo==="PPD" ) { %>
                            PPD - Pago en parcialidades o diferido
                            <% } else { %>
                              Sin definir
                              <% } %>
                      </p>
                    </div>

                    <div>
                      <p class="text-xs text-gray-400">Forma de Pago</p>
                      <p id="forma_pago" class="hidden">
                        <% if (factura.metodo_pago==="efectivo" ) { %>
                          01
                          <% } else if (factura.metodo_pago==="cheque nominativo" ) { %>
                            02
                            <% } else if (factura.metodo_pago==="transferencia" ) { %>
                              03
                              <% } else if (factura.metodo_pago==="tarjeta de credito" ) { %>
                                04
                                <% } else if (factura.metodo_pago==="tarjeta de debito" ) { %>
                                  28
                                  <% } else if (factura.metodo_pago==="por definir" ) { %>
                                    99
                                    <% } %>
                      </p>
                      <p class="font-semibold text-gray-800 mt-0.5">
                        <% if (factura.metodo_pago=='efectivo' ) { %>
                          01 - Efectivo
                          <% } else if (factura.metodo_pago=='transferencia' ) { %>
                            03 - Transferencia Electronica
                            <% } %>
                    </div>
                    <div>
                      <p class="text-xs text-gray-400">Uso CFDI</p>
                      <p id="cfdi" class="font-semibold text-gray-800 mt-0.5"></p>
                      <p id="RCFDI" class="hidden">
                        <%= factura.uso_cfdi %>
                      </p>
                    </div>

                  </div>
                </div>

              </div>
            </div>

            <!-- Modal Confirmar Eliminación -->
            <div id="modalConfirmDelete" class="hidden fixed inset-0 bg-black/50 items-center justify-center z-50">

              <div class="bg-white w-full max-w-md rounded-lg shadow-lg p-6 animate-fadeIn">

                <h2 class="text-lg font-semibold text-gray-800">
                  Confirmar Eliminación
                </h2>

                <p class="text-sm text-gray-600 mt-2 italic">
                  <span class="font-bold not-italic">¿Seguro que Deseas Eliminar el Borrador? </span>
                  <br> -Esta Acción no se Puede Deshacer.
                </p>

                <div class="flex justify-end gap-3 mt-6">

                  <button id="btnCancelarDelete" class="px-4 py-2 text-sm rounded border hover:bg-gray-100">
                    Cancelar
                  </button>

                  <button id="btnConfirmDelete"
                    class="px-4 py-2 text-sm rounded bg-red-600 text-white hover:bg-red-700">
                    Eliminar
                  </button>

                </div>
              </div>
            </div>

            <!-- Modal Confirmar Cancelación -->
            <div id="modalConfirmCancel" class="hidden fixed inset-0 bg-black/50 items-center justify-center z-50">

              <div class="bg-white w-full max-w-md rounded-lg shadow-lg p-6 animate-fadeIn">

                <h2 class="text-lg font-semibold text-gray-800">
                  Confirmar Cancelación
                </h2>

                <p class="text-sm text-gray-600 mt-2 italic">
                  <span class="font-bold not-italic">¿Seguro que Deseas Cancelar la Factura? </span>
                  <br> -Esta Acción no se Puede Deshacer.
                </p>

                <div class="flex justify-end gap-3 mt-6">

                  <button id="btnCancelarCancel" class="px-4 py-2 text-sm rounded border hover:bg-gray-100">
                    Cancelar
                  </button>

                  <button id="btnConfirmCancel"
                    class="px-4 py-2 text-sm rounded bg-red-600 text-white hover:bg-red-700">
                    Confirmar
                  </button>

                </div>
              </div>
            </div>

            <!-- Modal Confirmar Timbrado -->
            <div id="modalConfirmTimbrado" class="hidden fixed inset-0 bg-black/50 items-center justify-center z-50">

              <div class="bg-white w-full max-w-md rounded-lg shadow-lg p-6 animate-fadeIn">

                <h2 class="text-lg font-semibold text-gray-800">
                  Confirmar Timbrado
                </h2>

                <p class="text-sm text-gray-600 mt-2 italic">
                  <span class="font-bold not-italic">¿Seguro que Deseas Timbrar este Borrador? </span>
                  <br> - Verifica los Datos Antes de Hacerlo.
                </p>

                <div class="flex justify-end gap-3 mt-6">

                  <button id="btnCancelarTimbrado" class="px-4 py-2 text-sm rounded border hover:bg-gray-100">
                    Cancelar
                  </button>

                  <button id="btnConfirmTimbrado"
                    class="px-4 py-2 text-sm rounded bg-[#FF5100] text-white hover:bg-[#d94400]">
                    Confirmar
                  </button>

                </div>
              </div>
            </div>

            <!-- Modal de Carga -->
            <div id="modalGenerando" class="hidden fixed flex inset-0 bg-black/50 items-center justify-center z-50">

              <div class="bg-white w-full max-w-md rounded-lg shadow-lg p-6 animate-fadeIn text-center">

                <h2 id="textoCarga" class="text-lg font-semibold text-gray-800 pb-5">
                  Generando Factura...
                </h2>

                <div class="flex items-center justify-center pb-5">
                  <div class="h-12 w-12 animate-spin rounded-full border-4 border-gray-300 border-t-orange-600"></div>
                </div>
              </div>
            </div>

      </div>
    </div>


    <script src="/js/invoice-resume.js"></script>