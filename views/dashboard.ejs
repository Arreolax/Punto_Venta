<!-- Pantalla de carga -->
<%- include('../views/partials/loadingScreen', { loaderText: 'Cargando...' }) %>
  <%- include('./partials/alertModal') %>

    <!-- Contenido -->
    <div>
      <main class="pt-1 p-6">
        <div class="space-y-1">
          <h1 class="font-bold text-3xl">Inicio</h1>
        </div>
        <!-- Metricas -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-6 mt-6">
          <!-- Valor Inv -->
          <div class="bg-white p-5 rounded-xl shadow border border-gray-200">
            <p class="text-gray-500 text-sm">Valor de Inventario</p>
            <p class="text-2xl font-bold text-gray-900">$<%= Number(metrics.totalValue || 0).toLocaleString() %>
            </p>
            <div class="h-1 bg-orange-400 mt-3 w-full rounded"></div>
          </div>

          <!-- Productos Activos -->
          <div class="bg-white p-5 rounded-xl shadow border border-gray-200">
            <p class="text-gray-500 text-sm">Productos Activos</p>
            <h2 class="text-2xl font-bold mt-2">
              <%= metrics.totalProducts %>
            </h2>
            <div class="h-1 bg-orange-400 mt-3 w-full rounded"></div>
          </div>

          <!-- Bajo Stock -->
          <div class="bg-white p-5 rounded-xl shadow border border-gray-200">
            <p class="text-gray-500 text-sm">Productos con Bajo Stock</p>
            <h2 class="text-2xl font-bold mt-2 text-orange-600">
              <%= metrics.lowStock %>
            </h2>
            <div class="h-1 bg-orange-600 mt-3 w-1/2 rounded"></div>
          </div>

          <!-- Sin Stock -->
          <div class="bg-white p-5 rounded-xl shadow border border-gray-200">
            <p class="text-gray-500 text-sm">Productos Sin Stock</p>
            <h2 class="text-2xl font-bold mt-2 text-red-500">
              <%= metrics.zeroStock %>
            </h2>
            <div class="h-1 bg-red-500 mt-3 w-1 rounded"></div>
          </div>
        </div>

        <!-- Datos-->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
          <!-- Productos más vendidos -->
          <% if (salesD && salesD.length> 0) { %>
            <div class="md:col-span-2 bg-white p-5 rounded-xl space-y-5 shadow border border-gray-200">
              <div class="flex justify-between items-center">
                <h3 class="font-semibold">Productos más Vendidos</h3>

                <button id="toggleModo" class="bg-orange-500 text-white px-3 py-1 rounded-lg text-sm">
                  Ver por Total $
                </button>
              </div>

              <div class="h-72">
                <canvas id="salesChart" data-labels-cantidad='<%- JSON.stringify(labels) %>'
                  data-data-cantidad='<%- JSON.stringify(dataCantidad) %>'
                  data-labels-total='<%- JSON.stringify(labelsT) %>' data-data-total='<%- JSON.stringify(dataTotal) %>'>
                </canvas>
              </div>

              <div class="space-y-2">
                <h1 class="text-xl font-bold ">Productos</h1>
                <div class="max-h-64 overflow-y-auto border rounded-lg">
                  <table class="w-full text-sm">
                    <thead class="text-gray-500 border-b text-center sticky top-0 bg-white">
                      <tr>
                        <th class="py-2">Referencia</th>
                        <th>Nombre</th>
                        <th id="thCantidad">Cantidad Vendida</th>
                        <th id="thTotal">Total</th>
                      </tr>
                    </thead>
                    <tbody id="tablaProductos" class="text-center">


                      <% salesD.forEach(sale=> { %>
                        <tr class="border-b">
                          <td class="py-2">
                            <%= sale.referencia %>
                          </td>
                          <td class="py-2">
                            <%= sale.producto %>
                          </td>
                          <td class="tdCantidad py-2" data-cantidad="<%= sale.cantidad_vendida %>">
                            <%= sale.cantidad_vendida %> pz.
                          </td>
                          <td class="tdTotal" data-total="<%= sale.total %>">
                            $<%= sale.total %>
                          </td>
                        </tr>
                        <% }) %>


                    </tbody>
                  </table>
                </div>
              </div>
            </div>
            <% } else { %>
              <div class="md:col-span-2 bg-white p-5 rounded-xl shadow border border-gray-200 flex flex-col h-full">

                <div>
                  <h3 class="font-semibold">Productos más Vendidos</h3>
                </div>

                <div class="flex-1 flex flex-col items-center justify-center text-center space-y-3">
                  <i class="fa-solid fa-box-open text-4xl text-gray-400"></i>

                  <h3 class="font-semibold text-gray-700">
                    No hay productos vendidos
                  </h3>

                  <p class="text-sm text-gray-500">
                    Aún no se han registrado ventas en este periodo.
                  </p>
                </div>

              </div>
              <% } %>

                <!-- Distribución de Stock -->
                <div class="bg-white p-5 rounded-xl shadow border border-gray-200">
                  <% if (stockLabels.length> 0) { %>
                    <h3 class="font-semibold mb-4">Distribución de Stock</h3>

                    <div class="h-72 flex justify-center items-center">
                      <canvas id="stockChart" data-stock-labels='<%- JSON.stringify(stockLabels) %>'
                        data-stock-data='<%- JSON.stringify(stockData) %>'></canvas>
                    </div>

                    <div class="text-sm space-y-2">
                      <h1 class="text-xl font-bold ">Categorias</h1>
                      <div class="max-h-72 overflow-y-auto border-0 rounded-lg">
                        <ul>
                          <% stockLabels.forEach((label, i)=> {
                            const totalStock = stockData.reduce((a, b) => a + b, 0);
                            const value = stockData[i];
                            const porcentaje = totalStock ? ((value / totalStock) * 100).toFixed(2) : 0;
                            const labelText = Array.isArray(label) ? label.join(' ') : label;
                            %>

                            <div class="flex items-center justify-between text-sm mb-2">
                              <div class="flex items-center gap-2">
                                <span class="w-3 h-3 rounded-full"></span>
                                <span>
                                  <%= labelText%>
                                </span>
                              </div>
                              <span class="font-semibold">
                                <%= value %> pz.
                              </span>
                            </div>

                            <% }) %>
                        </ul>

                      </div>
                    </div>
                    <% } else { %>
                      <h3 class="font-semibold mb-4">Distribución de Stock</h3>

                      <div class="flex-1 flex flex-col items-center justify-center text-center space-y-3">
                        <i class="fa-solid fa-box-open text-4xl text-gray-400"></i>

                        <h3 class="font-semibold text-gray-700">
                          No hay categorias registrada
                        </h3>

                        <p class="text-sm text-gray-500">
                          Aún no se han registrado categorias con stock en este periodo.
                        </p>
                      </div>

                </div>

                <% } %>

        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Ventas Recientes -->
      <% if (recentSales && recentSales.length> 0) { %>
        <div class="md:col-span-2 bg-white p-5 rounded-xl shadow border border-gray-200">
          <div class="flex justify-between mb-4">
            <h3 class="font-semibold">Ventas Recientes</h3>
          </div>

          <div class="max-h-96 overflow-y-auto border rounded-lg">
            <table class="w-full text-sm">
              <thead class="text-gray-500 border-b text-center sticky top-0 bg-white">
                <tr>
                  <th class="py-2">Folio</th>
                  <th>Fecha</th>
                  <th>Cliente</th>
                  <th>Vendedor</th>
                  <th>Metodo de Pago</th>
                  <th>Cantidad de Productos</th>
                  <th>Total</th>
                </tr>
              </thead>
              <tbody class="text-center">
                <% recentSales.forEach(sale=> { %>
                  <tr class="border-b">
                    <td class="py-2">
                      <a href="/ventas/vista-previa/<%= sale.id %>" class="no-underline text-[#FF5100]"
                        title="Ver venta">
                        <%= sale.folio %>
                      </a>
                    </td>
                    <td>
                      <%= sale.fecha %>
                    </td>
                    <td>
                      <%= sale.nombre_cliente %>
                    </td>
                    <td>
                      <%= sale.nombre_empleado %>
                    </td>
                    <td>
                      <%= sale.metodo_pago.charAt(0).toUpperCase() + sale.metodo_pago.slice(1).toLowerCase() %>
                    </td>
                    <td>
                      <%= sale.cantidad %> pz.
                    </td>
                    <td class="text-green-700 font-semibold">
                      $<%= sale.total_pago %>
                    </td>
                  </tr>
                  <% }) %>
              </tbody>
            </table>
          </div>
        </div>
        <% } else { %>
          <div class="md:col-span-2 bg-white p-5 rounded-xl shadow border border-gray-200 flex flex-col h-full">

            <div>
              <h3 class="font-semibold">Ventas Recientes</h3>
            </div>

            <div class="flex-1 flex flex-col items-center justify-center text-center space-y-3">
              <i class="fa-solid fa-box-open text-4xl text-gray-400"></i>

              <h3 class="font-semibold text-gray-700">
                No hay ventas recientes
              </h3>
              <p class="text-sm text-gray-500">
                Aún no se han registrado ventas en este periodo.
              </p>
            </div>

          </div>
          <% } %>

            <!-- Alertas de Stock Bajo -->
            <div class="bg-white p-5 rounded-xl shadow border border-gray-200">

              <div class="flex justify-between items-center mb-4">
                <h3 id="stockTitle" class="font-semibold text-black flex items-center gap-2">
                  <i class="fa-solid fa-triangle-exclamation"></i>
                  Productos con Stock Bajo
                </h3>

                <button id="toggleStock" class="bg-orange-500 text-white px-3 py-1 rounded-lg text-sm">
                  Ver Productos sin Stock
                </button>
              </div>

              <div class="max-h-96 overflow-y-auto rounded-lg">

                <!-- Bajo stock -->
                <div id="lowStockList" class="space-y-4">
                  <% if (lowStockProducts.length> 0) { %>
                    <% lowStockProducts.forEach(product=> { %>
                      <div class="bg-gray-50 p-3 rounded">
                        <p class="font-semibold">
                          <%= product.name %>
                        </p>
                        <p class="text-xs text-gray-500">SKU: <%= product.sku %>
                        </p>

                        <div class="flex justify-between items-center mt-2">
                          <span class="text-orange-500 text-sm">
                            <%= product.stock %> unidades restantes
                          </span>

                          <a href="/inventario" class="text-xs bg-orange-500 text-white px-2 py-1 rounded">
                            Restock
                          </a>
                        </div>
                      </div>
                      <% }) %>
                        <% } else { %>
                          <div class="flex-1 flex flex-col items-center justify-center text-center space-y-3 pt-5">
                            <i class="fa-solid fa-box-open text-4xl text-gray-400"></i>
                            <h3 class="font-semibold text-gray-700">
                              No hay productos con bajo stock
                            </h3>
                          </div>
                          <% } %>
                </div>

                <!-- Sin stock -->
                <div id="zeroStockList" class="space-y-4 hidden">
                  <% if (zeroStockProducts.length> 0) { %>
                    <% zeroStockProducts.forEach(product=> { %>
                      <div class="bg-gray-50 p-3 rounded">
                        <p class="font-semibold">
                          <%= product.name %>
                        </p>
                        <p class="text-xs text-gray-500">SKU: <%= product.sku %>
                        </p>

                        <div class="flex justify-between items-center mt-2">
                          <span class="text-red-500 text-sm">
                            Sin stock
                          </span>

                          <a href="/inventario" class="text-xs bg-red-500 text-white px-2 py-1 rounded">
                            Restock urgente
                          </a>
                        </div>
                      </div>
                      <% }) %>
                        <% } else { %>
                          <p class="text-gray-500 text-sm">No hay productos sin stock</p>
                          <% } %>
                </div>

              </div>

            </div>

    </div>

    </main>

    </div>

    <script src="/libs/chart.js"></script>
    <script src="/js/dashboard.js"></script>