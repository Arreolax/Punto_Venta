<div class="h-[calc(83vh-3.5rem)] flex items-center justify-center bg-gray-100 text-center px-4">
  <div class="bg-white rounded-lg shadow-lg p-8 max-w-md w-full">
    <div class="text-7xl font-extrabold text-red-600 mb-4">403</div>
    <h2 class="text-2xl font-bold text-gray-800 mb-2">Acceso Denegado</h2>
    
    <div class="bg-red-50 border-l-4 border-red-600 p-4 mb-6 text-left rounded">
      <p class="text-gray-700 text-sm">
        <strong>⚠️ Permisos Insuficientes</strong>
        <br/>
        <%= message || 'No tienes los permisos necesarios para acceder a este recurso.' %>
      </p>
    </div>

    <div class="space-y-3">
      <a href="/dashboard" class="block w-full rounded bg-[#FF5100] px-6 py-3 text-white font-medium hover:bg-[#ba3216] transition">
        Dashboard
      </a>
      <a href="javascript:history.back()" class="block w-full rounded bg-gray-300 px-6 py-3 text-gray-800 font-medium hover:bg-gray-400 transition">
        Volver Atrás
      </a>
    </div>

    <p class="text-gray-500 text-sm mt-4">
      Si crees que esto es un error, contacta con tu administrador.
    </p>
  </div>
</div>