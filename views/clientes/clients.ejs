<!-- Pantalla de carga -->
<%- include('../partials/loadingScreen', { loaderText: 'Cargando Clientes...' }) %>

    <!-- Contenido -->
    <div id="contenido" class="hidden">
        <div class="w-full mx-auto">

            <div class="bg-white rounded-xl shadow border border-gray-200 mb-6 overflow-hidden">
                <div class="p-4 lg:p-5 border-b border-gray-300 bg-gradient-to-r from-white to-orange-50/40">
                    <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3">
                        <div>
                            <h1 class="font-bold text-xl sm:text-2xl lg:text-3xl text-slate-900">Clientes</h1>
                            <p class="text-gray-500 text-xs sm:text-sm">Administra los clientes</p>
                        </div>

                        <div class="flex flex-wrap gap-2">
                            <button id="btnNuevoCliente"
                                class="inline-flex items-center gap-2 bg-orange-500 text-white px-4 py-2 rounded-lg shadow-sm hover:bg-orange-600 text-sm font-medium">
                                <i class="fa-solid fa-user-plus"></i>
                                Agregar Nuevo Cliente
                            </button>
                        </div>

                    </div>
                </div>

                <div class="p-3 lg:p-4 flex flex-col sm:flex-row gap-2 sm:items-center">

                    <div class="relative flex-1 min-w-0">
                        <span
                            class="absolute left-2 sm:left-3 top-1/2 -translate-y-1/2 text-[#FF5100] text-xs sm:text-sm">
                            <i class="fa-solid fa-magnifying-glass text-gray-400"></i>
                        </span>

                        <input id="clientSearch" type="text" placeholder="Buscar por Correo Electronico, Nombre o RFC"
                            class="w-full border border-gray-400 rounded-lg pl-8 sm:pl-9 pr-3 sm:pr-4 py-1.5 sm:py-2 text-xs sm:text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" />
                    </div>

                    <select id="regimeFilter"
                        class="w-full sm:w-48 md:w-56 lg:w-96 border border-gray-400 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500">
                    </select>

                </div>
            </div>

            <% if (clients && clients.length> 0) { %>
                <div class="bg-white rounded shadow overflow-x-auto">

                    <table class="w-full table-fixed text-left text-xs lg:text-sm border-collapse">

                        <thead class="bg-gray-100 text-gray-600 text-[10px] lg:text-xs font-semibold sticky top-0">
                            <tr class="divide-x divide-gray-300/40">
                                <th class="p-3 lg:p-4 w-[170px]">Nombre</th>
                                <th class="p-3 lg:p-4 w-[150px]">Correo Electronico</th>
                                <th class="p-3 lg:p-4 w-[100px]">Telefono</th>
                                <th class="p-3 lg:p-4 w-[130px]">Direccion</th>
                                <th class="p-3 lg:p-4 w-[90px]">Codigo Postal</th>
                                <th class="p-3 lg:p-4 w-[220px]">Régimen Fiscal</th>
                                <th class="p-3 lg:p-4 w-[120px]">RFC</th>
                                <th class="p-3 lg:p-4 w-[120px] text-center">Acciones</th>
                            </tr>
                        </thead>

                        <tbody id="clientsTable" class="text-[10px] lg:text-xs divide-y">
                        </tbody>
                    </table>

                </div>
                <div id="clientsData" data-clients='<%- JSON.stringify(clients) %>'></div>
                <% } else { %>
                    <tr>
    <td colspan="8" class="p-6">
        <div class="flex flex-col items-center text-center text-gray-500">
            
            <div class="flex justify-center mb-4">
                <div class="bg-white p-5 rounded-full">
                    <i class="fa-solid fa-user-group text-3xl text-gray-400"></i>
                </div>
            </div>

            <h2 class="text-lg font-semibold text-gray-800">
                Sin Resultados
            </h2>

            <p class="text-gray-500 mt-2">
                No Se Encontraron Clientes Registrados.
            </p>

        </div>
    </td>
</tr>
                    <% } %>

                        <!-- Modal Form -->
                        <div id="modalCliente"
                            class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
                            <div class="bg-white w-full max-w-3xl rounded-xl shadow-lg relative overflow-hidden">

                                <!-- Header naranja -->
                                <div class="bg-orange-500 px-6 py-4 flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <div class="bg-white/20 rounded-lg p-2">
                                            <i class="fa-solid fa-user-plus text-white text-sm"></i>
                                        </div>
                                        <div>
                                            <h2 id="tituloModal" class="text-white font-bold text-lg leading-tight">
                                                Nuevo Cliente</h2>
                                            <p class="text-orange-100 text-xs">Completa la Informacion
                                            </p>
                                        </div>
                                    </div>
                                    <button id="cerrarModal" class="text-white/70 hover:text-white transition-colors">
                                        <i class="fa-solid fa-xmark text-lg"></i>
                                    </button>
                                </div>

                                <div class="flex gap-0">

                                    <!-- Formulario -->
                                    <form id="formCliente" class="flex-1 p-6">
                                        <input type="hidden" id="clienteId">

                                        <div class="grid grid-cols-1 gap-3">

                                            <!-- Nombre -->
                                            <div>
                                                <label class="text-xs font-semibold text-gray-600">Nombre o Razón
                                                    Social</label>
                                                <input required id="nombre" type="text"
                                                    placeholder="Ej. Soluciones Tecnológicas S.A. de C.V."
                                                    class="w-full mt-1 px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-[#FF5100]" />
                                            </div>

                                            <!-- RFC y Régimen -->
                                            <div class="grid grid-cols-2 gap-3">
                                                <div>
                                                    <label class="text-xs font-semibold text-gray-600">RFC</label>
                                                    <input required id="rfc" type="text" placeholder="ABCD010101XYZ"
                                                        maxlength="13"
                                                        class="w-full mt-1 px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-[#FF5100]" />
                                                    <p id="rfc-error" class="text-red-500 text-xs mt-1 hidden">RFC
                                                        inválido
                                                    </p>
                                                </div>

                                                <div>
                                                    <label class="text-xs font-semibold text-gray-600">Régimen
                                                        Fiscal</label>
                                                    <select required id="regimen_fiscal" name="cliente_regimen_fiscal"
                                                        class="w-full mt-1 px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-[#FF5100]">
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- Dirección -->
                                            <div>
                                                <label class="text-xs font-semibold text-gray-600">Dirección
                                                    (opcional)</label>
                                                <input id="direccion" type="text"
                                                    placeholder="Calle, número, colonia, municipio y estado"
                                                    class="w-full mt-1 px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-[#FF5100]" />
                                            </div>

                                            <!-- CP y Teléfono -->
                                            <div class="grid grid-cols-2 gap-3">
                                                <div>
                                                    <label class="text-xs font-semibold text-gray-600">Código
                                                        Postal</label>
                                                    <input required id="codigo_postal" type="text" inputmode="numeric"
                                                        placeholder="34000"
                                                        class="w-full mt-1 px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-[#FF5100]" />
                                                </div>
                                                <div>
                                                    <label class="text-xs font-semibold text-gray-600">Teléfono</label>
                                                    <input required id="telefono" type="text" inputmode="numeric"
                                                        placeholder="618 000 0000"
                                                        class="w-full mt-1 px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-[#FF5100]" />
                                                </div>
                                            </div>

                                            <!-- Correo -->
                                            <div>
                                                <label class="text-xs font-semibold text-gray-600">Correo
                                                    Electrónico</label>
                                                <input required id="email" type="email"
                                                    placeholder="cliente@empresa.com"
                                                    class="w-full mt-1 px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-1 focus:ring-[#FF5100]" />
                                            </div>

                                        </div>

                                        <!-- Botones -->
                                        <div class="flex justify-end gap-2 mt-5 pt-4 border-t border-gray-100">
                                            <button type="button" id="cancelar"
                                                class="px-4 py-2 text-sm border border-gray-300 text-gray-700 rounded-md font-semibold hover:bg-gray-50">
                                                Cancelar
                                            </button>
                                            <button type="submit" id="btnGuardar"
                                                class="flex items-center gap-2 px-4 py-2 text-sm bg-[#FF5100] text-white rounded-md font-semibold hover:bg-[#d94400]">
                                                <i class="fa-solid fa-user-plus"></i>
                                                Guardar Cliente
                                            </button>
                                        </div>
                                    </form>

                                    <!-- Panel lateral -->
                                    <div class="w-56 bg-gray-50 border-l border-gray-200 p-4 flex flex-col gap-4">

                                        <!-- Consejo -->
                                        <div class="bg-orange-50 border border-orange-200 rounded-lg p-3">
                                            <p class="text-xs font-bold text-orange-600 flex items-center gap-1 mb-1">
                                                <i class="fa-solid fa-circle-info"></i>
                                                Consejo Rápido
                                            </p>
                                            <p class="text-xs text-orange-700 leading-relaxed">
                                                Asegúrate de que el RFC coincida con la Constancia de Situación Fiscal
                                                para evitar futuros errores de timbrado.
                                            </p>
                                        </div>

                                        <!-- Progreso -->
                                        <div id="progresoModal">

                                            <div class="flex justify-between items-center mb-1">
                                                <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">
                                                    Progreso</p>
                                                <span id="modalPorcentaje"
                                                    class="text-xs font-semibold text-[#FF5100]">0%</span>
                                            </div>
                                            <div class="w-full bg-gray-200 rounded-full h-1.5 mb-3">
                                                <div id="modalBarra"
                                                    class="bg-[#FF5100] h-1.5 rounded-full transition-all duration-300"
                                                    style="width:0%"></div>
                                            </div>
                                            <div class="flex flex-col gap-2">
                                                <div class="flex items-center gap-2" id="modal-check-basicos">
                                                    <i class="fa-regular fa-circle-check text-gray-300 text-sm"></i>
                                                    <span class="text-xs text-gray-400">Datos Básicos</span>
                                                </div>
                                                <div class="flex items-center gap-2" id="modal-check-contacto">
                                                    <i class="fa-regular fa-circle-check text-gray-300 text-sm"></i>
                                                    <span class="text-xs text-gray-400">Contacto</span>
                                                </div>
                                                <div class="flex items-center gap-2" id="modal-check-fiscal">
                                                    <i class="fa-regular fa-circle-check text-gray-300 text-sm"></i>
                                                    <span class="text-xs text-gray-400">Datos Fiscales</span>
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                            </div>
                        </div>

                        <!-- Modal Confirmar Eliminación -->
                        <div id="modalConfirmDelete"
                            class="hidden fixed inset-0 bg-black/50 items-center justify-center z-50">

                            <div class="bg-white w-full max-w-md rounded-lg shadow-lg p-6 animate-fadeIn">

                                <h2 class="text-lg font-semibold text-gray-800">
                                    Confirmar Eliminación
                                </h2>

                                <p class="text-sm text-gray-600 mt-2 italic">
                                    <span class="font-bold not-italic">¿Seguro que Deseas Eliminar este Cliente? </span>
                                    <br> -Esta Acción no se Puede Deshacer.
                                </p>

                                <div class="flex justify-end gap-3 mt-6">

                                    <button id="btnCancelarDelete"
                                        class="px-4 py-2 text-sm rounded border hover:bg-gray-100">
                                        Cancelar
                                    </button>

                                    <button id="btnConfirmDelete"
                                        class="px-4 py-2 text-sm rounded bg-red-600 text-white hover:bg-red-700">
                                        Eliminar
                                    </button>

                                </div>
                            </div>
                        </div>
        </div>

    </div>

    <%- include('../partials/alertModal') %>

        <script src="/js/clients.js"></script>