<section class="flex-1 overflow-y-auto p-2 lg:p-3">
    <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="h-28 rounded-t-xl bg-orange-200"></div>

      <div class="flex flex-col gap-5 p-5 lg:p-6 md:flex-row md:items-center md:justify-between">
        <div class="relative">
          <img 
            id="profileImageDisplay" 
            src="<%= user.profile_image_path || '/images/user.jpg' %>" 
            alt="Foto de perfil" 
            class="w-24 h-24 rounded-full border-4 border-white -mt-16 object-cover shadow"
          >
          <button 
            id="changePhotoButton" 
            class="absolute bottom-0 right-0 bg-white text-gray-700 border border-gray-300 rounded-full w-9 h-9 flex items-center justify-center shadow-md hover:bg-gray-100"
            title="Cambiar foto"
            aria-label="Cambiar foto"
          >
            <i class="fa-solid fa-camera text-sm" aria-hidden="true"></i>
          </button>
        </div>

        <div class="flex-1 min-w-0">
          <h2 id="profileUsernameDisplay" class="text-2xl font-semibold text-slate-900"><%= (user.name || '') + (user.last_name ? ' ' + user.last_name : '') || user.username %></h2>
          <div class="mt-2 flex flex-wrap gap-2 text-xs">
            <span class="inline-flex items-center gap-1 px-2 py-1 rounded text-xs font-semibold <%= user.role_id === 2 ? 'bg-blue-100 text-blue-700' : 'bg-orange-100 text-orange-700' %>">
              <i class="fa-solid <%= user.role_id === 2 ? 'fa-user' : 'fa-user-shield' %> <%= user.role_id === 2 ? 'text-blue-500' : 'text-orange-500' %>"></i>
              <%= user.role_id === 1 ? 'Administrador' : user.role_id === 2 ? 'Vendedor' : user.role_id === 3 ? 'Interno' : 'Invitado' %>
            </span>
            <span class="inline-flex items-center gap-1 px-2 py-1 rounded text-xs font-semibold <%= user.is_active === false ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700' %>">
              <i class="fa-solid fa-circle text-[0.5rem] <%= user.is_active === false ? 'text-red-500' : 'text-green-500' %>"></i>
              <%= user.is_active === false ? 'Inactivo' : 'Activo' %>
            </span>
          </div>
          <div class="text-gray-500 text-sm mt-3">
            <span class="inline-flex items-center gap-1">
              <i class="fa-solid fa-phone text-gray-400"></i>
              <span id="profilePhoneDisplay"><%= user.phone || 'No registrado' %></span>
            </span>
            <span class="mx-2 text-gray-300">|</span>
            <span class="inline-flex items-center gap-1">
              <i class="fa-solid fa-envelope text-gray-400"></i>
              <span id="profileEmailDisplay"><%= user.email %></span>
            </span>
          </div>
        </div>

        <button id="editProfileButton" class="inline-flex items-center justify-center gap-2 bg-orange-500 text-white px-4 py-2 rounded-lg hover:bg-orange-600 text-sm font-medium shadow-sm transition">
          <i class="fa-solid fa-pen"></i>
          Editar Perfil
        </button>
      </div>
    </div>

    <div class="bg-white mt-6 rounded-xl border border-gray-200 shadow-sm overflow-hidden">
      <div class="border-b p-4 font-semibold text-gray-700 bg-gray-50">INFORMACIÓN DETALLADA</div>

      <div class="p-6 grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-6 text-gray-700">
        <span class="text-gray-500 text-xs tracking-wide">USUARIO</span>
        <span class="text-right font-medium"><%= user.username || '' %></span>

        <span class="text-gray-500 text-xs tracking-wide">NOMBRE</span>
        <span class="text-right font-medium"><%= (user.name || '') + (user.last_name ? ' ' + user.last_name : '') %></span>

        <span class="text-gray-500 text-xs tracking-wide">ROL</span>
        <span class="text-right font-medium"><%= user.role_id === 1 ? 'Administrador' : user.role_id === 2 ? 'Vendedor' : user.role_id === 3 ? 'Interno' : 'Invitado' %></span>

        <span class="text-gray-500 text-xs tracking-wide">PUESTO DE TRABAJO</span>
        <span class="text-right font-medium" id="displayJobPosition"><%= user.job_position || '' %></span>

        <span class="text-gray-500 text-xs tracking-wide">FECHA DE NACIMIENTO</span>
        <span class="text-right font-medium" id="displayBirthDate"><%= user.birth_date ? new Date(user.birth_date).toLocaleDateString('es-MX') : '' %></span>
      </div>
    </div>

    <div class="flex flex-col gap-3 md:flex-row md:justify-between md:items-center mt-6 p-2">
      <div class="text-gray-500 text-sm">
        <% const lastAccessFormatted = user.lastActivity ? new Date(user.lastActivity).toLocaleString('es-MX') : 'Sin registro'; %>
        Último acceso: <%= lastAccessFormatted %>
      </div>

      <div class="flex gap-2">
        <a href="/dashboard" class="border border-orange-300 px-4 py-2 rounded-lg text-gray-700 hover:bg-orange-50 text-sm font-medium transition">Regresar</a>
        <!-- 
        <a href="/movimiento" class="bg-orange-500 text-white px-4 py-2 rounded hover:bg-orange-600">Movimientos</a>
        -->
      </div>
    </div>
  </section>

<%- include('../partials/alertModal') %>

<!-- Modal para cambiar foto de perfil -->
<div id="changePhotoModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
  <div class="bg-white rounded-lg shadow-lg p-6 max-w-sm w-full mx-4 relative">
    <button id="closeChangePhotoModalPerfil" type="button" class="absolute top-3 right-3 text-gray-500 hover:text-gray-700 transition" aria-label="Cerrar cambiar foto de perfil">
      <i class="fa-solid fa-xmark text-lg"></i>
    </button>
    <h3 class="text-lg font-semibold mb-2 text-center">Cambiar Foto de Perfil</h3>
    
    <form id="changePhotoForm" enctype="multipart/form-data">
      <p class="text-sm text-gray-600 mb-4 text-center">Selecciona una imagen</p>
      
      <!-- Zona de drag and drop -->
      <div 
        id="dropZone"
        class="mb-4 border-2 border-dashed border-gray-300 rounded-lg p-6 text-center cursor-pointer hover:border-orange-400 hover:bg-orange-50 transition"
        style="background-color: #f9fafb;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-2 text-gray-400">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        <input 
          id="changePhotoInput" 
          name="profileImage" 
          type="file" 
          accept="image/jpeg,image/png" 
          class="hidden"
        >
        <p class="text-sm text-gray-600 mb-1">
          <span id="fileNameDisplay">Ningún archivo seleccionado</span>
        </p>
        <p class="text-xs text-gray-500">
          <button type="button" id="selectFileBtn" class="text-orange-600 hover:text-orange-700 font-medium">
            Seleccionar archivo
          </button>
          o arrastra aquí
        </p>
      </div>

      <p class="text-xs text-gray-500 mb-4 text-center">Formatos JPG, JPEG, PNG. Tamaño máximo 5 MB.</p>
      
      <div id="changePhotoError" class="text-xs text-red-500 mb-4 text-center" style="display: none;"></div>

      <div class="mb-6 text-center">
        <img 
          id="changePhotoPreview" 
          src="/images/user.jpg" 
          alt="Preview" 
          class="w-32 h-32 rounded-full border-4 border-gray-200 object-cover mx-auto"
        >
      </div>

      <div class="flex gap-3 justify-center">
        <button type="button" id="cancelChangePhoto" class="px-6 py-2 border border-gray-300 rounded hover:bg-gray-100 text-sm font-medium transition">
          Cancelar
        </button>
        <button type="submit" id="submitChangePhoto" class="px-6 py-2 bg-orange-500 text-white rounded hover:bg-orange-600 text-sm font-medium transition" disabled>
          Guardar Foto
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Input file hidden para cambios de foto rápidos -->
<input type="file" id="hiddenProfileImageInput" accept="image/jpeg,image/png" style="display: none;">

<!-- Modal de éxito reutilizable -->
<div id="successModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
  <div class="relative bg-white rounded-lg shadow-lg p-8 max-w-sm w-full mx-4 text-center">
    <button type="button" id="closeSuccessModalX" class="absolute right-4 top-4 text-gray-500 hover:text-gray-700" aria-label="Cerrar mensaje">
      <i class="fa-solid fa-xmark text-lg"></i>
    </button>
    <div class="w-16 h-16 mx-auto mb-4 bg-green-100 rounded-full flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
    </div>
    <h3 id="successModalTitle" class="text-lg font-semibold mb-2">¡Listo!</h3>
    <p id="successModalMessage" class="text-gray-600 text-sm mb-6">La operación se realizó correctamente.</p>
    <button id="closeSuccessModal" type="button" class="px-6 py-2 bg-green-500 text-white rounded hover:bg-green-600 text-sm font-medium transition">
      Aceptar
    </button>
  </div>
</div>

<script>
  const successModal = document.getElementById('successModal');
  const successModalTitle = document.getElementById('successModalTitle');
  const successModalMessage = document.getElementById('successModalMessage');
  const closeSuccessModalBtn = document.getElementById('closeSuccessModal');
  const closeSuccessModalXBtn = document.getElementById('closeSuccessModalX');

  const hideSuccessModal = () => {
    successModal.classList.add('hidden');
  };

  // Funcion para mostrar modal de exito
  function showSuccessModal(title = '¡Listo!', message = 'La operación se realizó correctamente.') {
    successModalTitle.textContent = title;
    successModalMessage.textContent = message;
    successModal.classList.remove('hidden');

    setTimeout(() => {
      hideSuccessModal();
    }, 4000);
  }

  closeSuccessModalBtn?.addEventListener('click', hideSuccessModal);
  closeSuccessModalXBtn?.addEventListener('click', hideSuccessModal);
</script>

<script>
  // Modal para cambiar foto
  const changePhotoModal = document.getElementById('changePhotoModal');
  const changePhotoButton = document.getElementById('changePhotoButton');
  const cancelChangePhoto = document.getElementById('cancelChangePhoto');
  const closeChangePhotoModalPerfil = document.getElementById('closeChangePhotoModalPerfil');
  const changePhotoInput = document.getElementById('changePhotoInput');
  const changePhotoPreview = document.getElementById('changePhotoPreview');
  const changePhotoError = document.getElementById('changePhotoError');
  const changePhotoForm = document.getElementById('changePhotoForm');
  const submitChangePhoto = document.getElementById('submitChangePhoto');
  const hideChangePhotoModal = () => {
    changePhotoModal.classList.add('hidden');
  };

  // Abrir modal
  changePhotoButton.addEventListener('click', () => {
    changePhotoModal.classList.remove('hidden');
    changePhotoInput.value = '';
    fileNameDisplay.textContent = 'Ningún archivo seleccionado';
    changePhotoPreview.src = '/images/user.jpg';
    changePhotoError.style.display = 'none';
    submitChangePhoto.disabled = true;
  });

  // Cerrar modal
  cancelChangePhoto.addEventListener('click', () => {
    hideChangePhotoModal();
  });
  closeChangePhotoModalBtn?.addEventListener('click', hideChangePhotoModal);

  changePhotoModal.addEventListener('click', (event) => {
    if (event.target === changePhotoModal) hideChangePhotoModal();
  });

  successModal.addEventListener('click', (event) => {
    if (event.target === successModal) hideSuccessModal();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key !== 'Escape') return;
    if (!changePhotoModal.classList.contains('hidden')) hideChangePhotoModal();
    if (!successModal.classList.contains('hidden')) hideSuccessModal();
  });

  if (closeChangePhotoModalPerfil) {
    closeChangePhotoModalPerfil.addEventListener('click', () => {
      changePhotoModal.classList.add('hidden');
    });
  }

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !changePhotoModal.classList.contains('hidden')) {
      changePhotoModal.classList.add('hidden');
    }
  });

  const MAX_SIZE = 5 * 1024 * 1024; // 5 MB
  const ALLOWED_TYPES = ['image/jpeg', 'image/png'];
  const dropZone = document.getElementById('dropZone');
  const selectFileBtn = document.getElementById('selectFileBtn');
  const fileNameDisplay = document.getElementById('fileNameDisplay');

  // Validar archivo
  const validateFile = (file) => {
    changePhotoError.style.display = 'none';
    changePhotoError.textContent = '';
    submitChangePhoto.disabled = true;

    if (!file) return false;

    if (!ALLOWED_TYPES.includes(file.type)) {
      changePhotoError.textContent = 'Error: Solo JPG, JPEG y PNG están permitidos';
      changePhotoError.style.display = 'block';
      return false;
    }

    if (file.size > MAX_SIZE) {
      changePhotoError.textContent = `Error: El archivo excede 5 MB (${(file.size / 1024 / 1024).toFixed(2)} MB)`;
      changePhotoError.style.display = 'block';
      return false;
    }

    return true;
  };

  // Mostrar preview
  const showPreview = (file) => {
    const reader = new FileReader();
    reader.onload = function(event) {
      changePhotoPreview.src = event.target.result;
      submitChangePhoto.disabled = false;
    };
    reader.readAsDataURL(file);
  };

  // Click en botón "Seleccionar archivo"
  selectFileBtn.addEventListener('click', (e) => {
    e.preventDefault();
    changePhotoInput.click();
  });

  // Click en zona de drop
  dropZone.addEventListener('click', () => {
    changePhotoInput.click();
  });

  // Cambio de archivo
  changePhotoInput.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      fileNameDisplay.textContent = file.name;
      if (validateFile(file)) {
        showPreview(file);
      } else {
        changePhotoInput.value = '';
        fileNameDisplay.textContent = 'Ningún archivo seleccionado';
      }
    }
  });

  // Drag and drop
  dropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropZone.classList.add('border-orange-400', 'bg-orange-50');
  });

  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-orange-400', 'bg-orange-50');
  });

  dropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-orange-400', 'bg-orange-50');
    
    const file = e.dataTransfer.files[0];
    if (file) {
      fileNameDisplay.textContent = file.name;
      changePhotoInput.files = e.dataTransfer.files;
      if (validateFile(file)) {
        showPreview(file);
      } else {
        changePhotoInput.value = '';
        fileNameDisplay.textContent = 'Ningún archivo seleccionado';
      }
    }
  });

  // Enviar cambio de foto
  changePhotoForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(changePhotoForm);
    
    try {
      const response = await fetch('/api/auth/profile-image', {
        method: 'POST',
        credentials: 'include',
        body: formData
      });

      if (response.ok) {
        const data = await response.json();
        // Actualizar imagen en la página
        document.getElementById('profileImageDisplay').src = data.data.profile_image_path;
        hideChangePhotoModal();
        mostrarAlerta('success', data.message || 'Foto de perfil actualizada correctamente');
      } else {
        const error = await response.json();
        mostrarAlerta('error', error.message || 'Error al actualizar la foto');
      }
    } catch (error) {
      console.error('Error:', error);
      mostrarAlerta('error', 'Error al actualizar la foto');
    }
  });

  // Cargar datos de perfil completos (incluyendo campos de perfil)
  async function loadProfileData() {
    try {
      const response = await fetch('/api/auth/profile', {
        method: 'GET',
        credentials: 'include'
      });
      
      if (response.ok) {
        const data = await response.json();
        const user = data.data?.user;
        
        if (user) {
          // Actualizar elementos en la página con los datos del servidor
          if (user.job_position) {
            document.getElementById('displayJobPosition').textContent = user.job_position || '';
          }
          
          if (user.birth_date) {
            const birthDate = new Date(user.birth_date).toLocaleDateString('es-MX');
            document.getElementById('displayBirthDate').textContent = birthDate;
          }

          // Actualizar imagen de perfil
          if (user.profile_image_path) {
            document.getElementById('profileImageDisplay').src = user.profile_image_path;
          }
          
          // Guardar en localStorage para usar en otras vistas
          localStorage.setItem('userProfile', JSON.stringify(user));
        }
      }
    } catch (error) {
      console.warn('No se pudieron cargar datos completos de perfil:', error);
    }
  }
  
  // Ejecutar al cargar la página
  document.addEventListener('DOMContentLoaded', loadProfileData);
</script>
