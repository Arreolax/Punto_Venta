<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Restablecer Contraseña</title>
  <link rel="icon" type="image/png" href="/images/favicon.png">
  <link href="/styles/styles.css" rel="stylesheet">
  <link rel="stylesheet" href="../../libs/fontawesome/css/all.min.css">
</head>

<body class="bg-gray-100">

<div class="relative min-h-screen flex items-center justify-center bg-gray-100 overflow-hidden">

  <!-- Fondo naranja izquierdo -->
  <div class="absolute top-0 left-0 w-1/2 h-full bg-orange-600"
    style="clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);">
  </div>

  <!-- Fondo naranja derecho -->
  <div class="absolute top-0 right-0 w-1/2 h-full bg-orange-600"
    style="clip-path: polygon(0 0, 100% 0, 100% 45%, 0 45%);">
  </div>

  <!-- Contenedor principal -->
  <div class="relative bg-orange-600 w-[425px] p-8 shadow-md text-center">
    <div class="relative bg-white w-[360px] p-8 shadow-md text-center mx-auto">

      <div class="flex justify-center mb-6">
        <img src="/images/logo-b.png" class="w-full h-auto" alt="Logo" style="max-width: 350px;">
      </div>

      <h2 class="text-xl font-semibold mb-2">Restablecer Contraseña</h2>
      <p class="text-sm text-gray-600 mb-6">Crea una contraseña segura y robusta</p>

      <!-- Formulario de reseteo -->
      <form id="resetForm" class="space-y-4">

        <!-- Mensaje de error -->
        <div id="errorMessage" class="text-red-600 text-sm p-3 bg-red-100 rounded hidden">
          <i class="fas fa-exclamation-circle"></i>
          <span id="errorText"></span>
        </div>

        <!-- Mensaje de éxito -->
        <div id="successMessage" class="text-green-600 text-sm p-3 bg-green-100 rounded hidden">
          <i class="fas fa-check-circle"></i>
          <span id="successText"></span>
        </div>

        <!-- Nueva contraseña mejorada -->
        <div class="mt-4">
          <label class="text-sm text-gray-700 font-medium block mb-2">Contraseña Nueva</label>
          <div class="relative mb-2">
            <input type="password" id="newPassword" placeholder="Ingresa tu nueva contraseña"
                   class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-orange-500" required>
            <button type="button" id="toggleNewPassword" class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-700 transition">
              <i id="toggleNewPasswordIcon" class="fa-solid fa-eye"></i>
            </button>
          </div>
          
          <!-- Caps Lock indicator -->
          <div id="newPasswordCapsWarning" class="text-xs text-yellow-600 hidden flex items-center gap-1 mb-2">
            <i class="fa-solid fa-triangle-exclamation"></i>
            <span>Bloq Mayus activado</span>
          </div>
          
          <!-- Requisitos de contraseña visibles -->
          <div class="bg-gray-50 border border-gray-200 rounded p-3 mb-3">
            <p class="text-xs font-semibold text-gray-700 mb-2">Requisitos de contraseña:</p>
            <div class="space-y-1.5">
              <div class="flex items-center gap-2">
                <i id="reqLength" class="fa-solid fa-circle text-gray-300" style="font-size: 0.35rem;"></i>
                <span class="text-xs text-gray-600">Mínimo 8 caracteres</span>
              </div>
              <div class="flex items-center gap-2">
                <i id="reqUppercase" class="fa-solid fa-circle text-gray-300" style="font-size: 0.35rem;"></i>
                <span class="text-xs text-gray-600">Al menos una mayúscula (A-Z)</span>
              </div>
              <div class="flex items-center gap-2">
                <i id="reqLowercase" class="fa-solid fa-circle text-gray-300" style="font-size: 0.35rem;"></i>
                <span class="text-xs text-gray-600">Al menos una minúscula (a-z)</span>
              </div>
              <div class="flex items-center gap-2">
                <i id="reqNumber" class="fa-solid fa-circle text-gray-300" style="font-size: 0.35rem;"></i>
                <span class="text-xs text-gray-600">Al menos un número (0-9)</span>
              </div>
            </div>
          </div>
          
          <!-- Indicador de seguridad -->
          <div class="mb-3">
            <div class="flex items-center gap-2 text-xs mb-1">
              <span class="text-gray-600">Seguridad:</span>
              <div id="passwordStrength" class="flex gap-1 flex-1">
                <div class="h-1 flex-1 bg-gray-300 rounded"></div>
                <div class="h-1 flex-1 bg-gray-300 rounded"></div>
                <div class="h-1 flex-1 bg-gray-300 rounded"></div>
                <div class="h-1 flex-1 bg-gray-300 rounded"></div>
              </div>
            </div>
            <p id="strengthText" class="text-xs text-gray-500">Escribe tu contraseña para ver su seguridad</p>
          </div>
        </div>

        <!-- Botones -->
        <div class="flex flex-col items-center gap-2 mt-6">
          <button type="submit" class="inline-block rounded bg-[#FF5100] px-6 py-3 text-white font-medium hover:bg-[#ba3216] transition w-full">
            Restablecer Contraseña
          </button>
        
          <a href="/" class="text-sm text-gray-700 hover:underline">
            Regresar
          </a>
        </div>

      </form>

    </div>
  </div>

</div>

<script src="/js/page-scripts.js"></script>

<script>
  /**
   * Obtener token de la URL
   */
  function getTokenFromURL() {
    const urlParams = new URLSearchParams(window.location.search);
    return urlParams.get('token');
  }

  /**
   * Calcular la fortaleza de la contraseña
   */
  function updatePasswordRequirements(password) {
    // Validar cada requisito
    const hasMinLength = password.length >= 8;
    const hasUppercase = /[A-Z]/.test(password);
    const hasLowercase = /[a-z]/.test(password);
    const hasNumber = /\d/.test(password);

    // Actualizar indicadores de requisitos
    const reqElements = {
        'reqLength': hasMinLength,
        'reqUppercase': hasUppercase,
        'reqLowercase': hasLowercase,
        'reqNumber': hasNumber
    };

    for (const [id, met] of Object.entries(reqElements)) {
        const element = document.getElementById(id);
        if (element) {
            if (met) {
                element.classList.remove('text-gray-300');
                element.classList.add('text-green-500');
            } else {
                element.classList.remove('text-green-500');
                element.classList.add('text-gray-300');
            }
        }
    }
  }

  function calculatePasswordStrength(password) {
    // Actualizar requisitos
    updatePasswordRequirements(password);

    // Calcular fortaleza
    const strengthBars = document.querySelectorAll('#passwordStrength .h-1');
    const strengthText = document.getElementById('strengthText');
    let strength = 0;

    if (password.length >= 8) strength++;
    if (password.length >= 12) strength++;
    if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
    if (/\d/.test(password)) strength++;

    strengthBars.forEach((bar, i) => {
      if (i < strength) {
        bar.classList.remove('bg-gray-300');
        if (strength <= 2) bar.classList.add('bg-red-500');
        else if (strength === 3) bar.classList.add('bg-yellow-500');
        else bar.classList.add('bg-green-500');
      } else {
        bar.classList.add('bg-gray-300');
        bar.classList.remove('bg-red-500', 'bg-yellow-500', 'bg-green-500');
      }
    });

    const strengthLabels = ['Muy débil', 'Débil', 'Media', 'Fuerte'];
    strengthText.textContent = strength > 0 ? strengthLabels[strength - 1] : 'Escribe tu contraseña para ver su fortaleza';
  }

  /**
   * Manejar el envío del formulario
   */
  document.getElementById('resetForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const token = getTokenFromURL();
    const newPassword = document.getElementById('newPassword').value;

    // Validaciones
    if (!token) {
      showError('Token no válido');
      return;
    }

    if (newPassword.length < 8) {
      showError('La contraseña debe tener mínimo 8 caracteres');
      return;
    }

    if (!/[A-Z]/.test(newPassword) || !/[a-z]/.test(newPassword) || !/\d/.test(newPassword)) {
      showError('La contraseña debe tener mayúsculas, minúsculas y números');
      return;
    }

    try {
      // Enviar solicitud POST a API
      const response = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          token: token,
          newPassword: newPassword
        })
      });

      const data = await response.json();

      if (response.ok && data.success) {
        // Mostrar éxito
        document.getElementById('successMessage').classList.remove('hidden');
        document.getElementById('successText').textContent = 'Contraseña reseteada correctamente. Redirigiendo...';
        document.getElementById('resetForm').style.display = 'none';
        
        // Redirigir a login después de 3 segundos
        setTimeout(() => {
          window.location.href = '/';
        }, 3000);
      } else {
        showError(data.message || 'Error al restablecer contraseña');
      }
    } catch (error) {
      console.error('Error:', error);
      showError('Error de conexión. Por favor intenta más tarde.');
    }
  });

  /**
   * Mostrar error
   */
  function showError(message) {
    const errorDiv = document.getElementById('errorMessage');
    const errorText = document.getElementById('errorText');
    errorText.textContent = message;
    errorDiv.classList.remove('hidden');
  }

  /**
   * Monitorear cambios en la contraseña para mostrar fortaleza
   */
  document.getElementById('newPassword').addEventListener('input', (e) => {
    calculatePasswordStrength(e.target.value);
  });

  function bindResetPasswordToggle(buttonId, inputId, iconId) {
    const button = document.getElementById(buttonId);
    const input = document.getElementById(inputId);
    const icon = document.getElementById(iconId);
    if (!button || !input || !icon) return;

    button.addEventListener('click', () => {
      const isHidden = input.type === 'password';
      input.type = isHidden ? 'text' : 'password';
      icon.classList.toggle('fa-eye');
      icon.classList.toggle('fa-eye-slash');
    });
  }

  bindResetPasswordToggle('toggleNewPassword', 'newPassword', 'toggleNewPasswordIcon');

  // Caps Lock indicator para nueva contraseña
  const newPasswordInput = document.getElementById('newPassword');
  const newPasswordCapsWarning = document.getElementById('newPasswordCapsWarning');

  if (newPasswordInput && newPasswordCapsWarning) {
    newPasswordInput.addEventListener('keydown', (e) => {
      const isCapsLock = e.getModifierState('CapsLock');
      if (isCapsLock) {
        newPasswordCapsWarning.classList.remove('hidden');
      } else {
        newPasswordCapsWarning.classList.add('hidden');
      }
    });

    newPasswordInput.addEventListener('keyup', (e) => {
      const isCapsLock = e.getModifierState('CapsLock');
      if (isCapsLock) {
        newPasswordCapsWarning.classList.remove('hidden');
      } else {
        newPasswordCapsWarning.classList.add('hidden');
      }
    });
  }

  /**
   * Inicializar
   */
  window.addEventListener('load', () => {
    const token = getTokenFromURL();
    if (!token) {
      document.getElementById('resetForm').style.display = 'none';
      showError('No se encontró un token válido de recuperación. Por favor solicita uno nuevo.');
    }
  });
</script>

</body>
</html>
