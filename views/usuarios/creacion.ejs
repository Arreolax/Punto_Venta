<div class="flex flex-col lg:flex-row lg:justify-between lg:items-center mb-6 gap-4">
            <div>
                <h2 class="text-xl lg:text-2xl font-bold mb-1">Crear Nuevo Usuario</h2>
                <p class="text-gray-500 mb-0 text-sm lg:text-base">Completa la información detallada para registrar un nuevo colaborador.</p>
            </div>
        </div>

        <div class="bg-white p-3 lg:p-8 rounded shadow">

        <form id="createUserForm" enctype="multipart/form-data">

        <!-- INFORMACION PERSONAL -->
        <h3 class="font-semibold text-gray-700 border-b pb-2 mt-6 lg:mt-8 mb-3 lg:mb-4 flex items-center gap-2 text-sm lg:text-base">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
            </svg>
            <span>Información Personal</span>
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">

            <div>
                <label class="text-xs md:text-sm text-gray-600">Nombre</label>
                <input id="firstName" name="firstName" type="text" placeholder="Ej. Juan Carlos" class="w-full border rounded px-3 py-2 mt-1 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500">
            </div>

            <div>
                <label class="text-xs md:text-sm text-gray-600">Apellido</label>
                <input id="lastName" name="lastName" type="text" placeholder="Ej. Pérez García" class="w-full border rounded px-3 py-2 mt-1 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500">
            </div>

            <div>
                <label class="text-xs md:text-sm text-gray-600">Email</label>
                <input id="email" name="email" type="email" placeholder="juan@email.com" class="w-full border rounded px-3 py-2 mt-1 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500">
            </div>

            <div>
                <label class="text-xs md:text-sm text-gray-600">Teléfono</label>
                <input id="phone" name="phone" type="text" inputmode="numeric" autocomplete="tel" value="+52 " placeholder="+52 618 238 97 64" class="w-full border rounded px-3 py-2 mt-1 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500">
            </div>

        </div>


        <!-- IMAGEN DE PERFIL (OPCIONAL) -->
        <h3 class="font-semibold text-gray-700 border-b pb-2 mt-6 lg:mt-8 mb-3 lg:mb-4 flex items-center gap-2 text-sm lg:text-base">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
            </svg>
            <span>Imagen de Perfil (Opcional)</span>
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">

            <div class="md:col-span-2">
                <label class="text-xs md:text-sm text-gray-600">Foto de perfil</label>
                <div 
                    id="profileImageDropZone"
                    class="w-full border-2 border-dashed border-gray-300 rounded px-6 py-12 mt-1 text-center cursor-pointer hover:border-orange-400 hover:bg-orange-50 transition"
                >
                    <div class="flex flex-col items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-400">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                            <polyline points="7 10 12 15 17 10"/>
                            <line x1="12" y1="15" x2="12" y2="3"/>
                        </svg>
                        <div>
                            <p class="text-sm text-gray-600">Haz clic para seleccionar</p>
                            <p class="text-xs text-gray-500">o arrastra la imagen aquí</p>
                        </div>
                    </div>
                </div>
                <p class="text-xs text-gray-500 mt-2">Formatos permitidos: JPG, JPEG, PNG. Máximo 5 MB.</p>
                <div id="profileImageError" class="text-xs text-red-500 mt-2" style="display: none;"></div>
                <input 
                    id="profileImage" 
                    name="profileImage" 
                    type="file" 
                    accept="image/jpeg,image/png" 
                    class="hidden"
                >
            </div>

            <div class="text-center">
                <p class="text-xs md:text-sm text-gray-600 mb-2">Vista previa</p>
                <img 
                    id="profileImagePreview" 
                    src="/images/user.jpg" 
                    alt="Preview" 
                    class="w-24 md:w-32 h-24 md:h-32 rounded-full border-4 border-gray-300 object-cover mx-auto"
                >
            </div>

        </div>

        <!-- DETALLES DE LA CUENTA -->
        <div class="mt-8 lg:mt-10 border-t border-gray-200 pt-6 lg:pt-8">
            <div class="flex items-center gap-3 mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600 shrink-0" aria-hidden="true">
                    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
                    <path d="m3.3 7 8.7 5 8.7-5"/>
                    <path d="M12 22V12"/>
                </svg>
                <h3 class="text-lg font-bold text-slate-900">Detalles de la Cuenta</h3>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-6">

            <div>
                <label class="text-xs md:text-sm text-gray-600">Nombre de usuario</label>
                <input id="username" name="username" type="text" class="w-full border rounded px-3 py-2 mt-1 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500">
            </div>

            <div>
                <label class="text-xs md:text-sm text-gray-600">Rol</label>
                <select id="roleId" name="roleId" class="w-full border rounded px-3 py-2 mt-1 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500">
                    <option value="">Seleccione un rol</option>
                    <option value="1">Administrador</option>
                    <option value="2">Vendedor</option>
                </select>
            </div>

            <div>
                <label class="text-xs md:text-sm text-gray-600">Puesto de trabajo</label>
                <input id="jobPosition" name="jobPosition" type="text" class="w-full border rounded px-3 py-2 mt-1 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500">
            </div>

            <div>
                <label class="text-xs md:text-sm text-gray-600">Fecha de nacimiento</label>
                <input id="birthDate" name="birthDate" type="date" min="1930-01-01" max="2009-12-31" class="w-full border rounded px-3 py-2 mt-1 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500">
            </div>

            </div>
        </div>

        <!-- CREDENCIALES DE ACCESO -->
        <div class="mt-8 lg:mt-10 border-t border-gray-200 pt-6 lg:pt-8">
            <div class="flex items-center gap-3 mb-6">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-600 shrink-0" aria-hidden="true">
                    <circle cx="12" cy="16" r="1"/>
                    <rect width="18" height="12" x="3" y="10" rx="2"/>
                    <path d="M7 10V7a5 5 0 0 1 10 0v3"/>
                </svg>
                <h3 class="text-lg font-bold text-slate-900">Credenciales de Acceso</h3>
            </div>

            <div>
            <label class="text-xs lg:text-sm text-gray-600 block mb-2">Contraseña</label>
            <div class="relative mt-1 mb-3">
                <input id="password" name="password" type="password" class="w-full border rounded px-3 py-2 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="Mínimo 8 caracteres">
                <button id="toggleCreatePassword" type="button" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-800 transition">
                    <i id="toggleCreatePasswordIcon" class="fa-solid fa-eye"></i>
                </button>
            </div>
            
            <!-- Confirmar Contraseña -->
            <label class="text-xs lg:text-sm text-gray-600 block mb-2 mt-4">Confirmar Contraseña</label>
            <div class="relative mt-1 mb-3">
                <input id="confirmPassword" name="confirmPassword" type="password" class="w-full border rounded px-3 py-2 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-orange-500" placeholder="Confirma tu contraseña">
                <button id="toggleConfirmPassword" type="button" class="absolute right-2 top-1/2 -translate-y-1/2 text-gray-500 hover:text-gray-800 transition">
                    <i id="toggleConfirmPasswordIcon" class="fa-solid fa-eye"></i>
                </button>
            </div>
            
            <!-- Caps Lock indicator -->
            <div id="createPasswordCapsWarning" class="text-xs text-yellow-600 hidden flex items-center gap-1 mb-2">
                <i class="fa-solid fa-triangle-exclamation"></i>
                <span>Bloq Mayus activado</span>
            </div>
            
            <!-- Requisitos de contraseña visibles -->
            <div class="bg-gray-50 border border-gray-200 rounded p-3 mt-2 mb-3">
                <p class="text-xs font-semibold text-gray-700 mb-2">Requisitos de contraseña:</p>
                <div class="space-y-1.5">
                    <div class="flex items-center gap-2">
                        <i id="reqLength" class="fa-solid fa-circle text-gray-300" style="font-size: 0.35rem;"></i>
                        <span class="text-xs text-gray-600">Mínimo 8 caracteres</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i id="reqUppercase" class="fa-solid fa-circle text-gray-300" style="font-size: 0.35rem;"></i>
                        <span class="text-xs text-gray-600">Al menos una mayúscula (A-Z)</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i id="reqLowercase" class="fa-solid fa-circle text-gray-300" style="font-size: 0.35rem;"></i>
                        <span class="text-xs text-gray-600">Al menos una minúscula (a-z)</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <i id="reqNumber" class="fa-solid fa-circle text-gray-300" style="font-size: 0.35rem;"></i>
                        <span class="text-xs text-gray-600">Al menos un número (0-9)</span>
                    </div>
                </div>
            </div>
            
            <!-- Indicador de seguridad -->
            <div class="mb-3">
              <div class="flex items-center gap-2 text-xs mb-1">
                <span class="text-gray-600">Seguridad:</span>
                    <div id="createPasswordStrength" class="flex gap-1 flex-1">
                        <div class="h-1 flex-1 bg-gray-300 rounded"></div>
                        <div class="h-1 flex-1 bg-gray-300 rounded"></div>
                        <div class="h-1 flex-1 bg-gray-300 rounded"></div>
                        <div class="h-1 flex-1 bg-gray-300 rounded"></div>
                    </div>
                </div>
                <p id="createStrengthText" class="text-xs text-gray-500">Escribe tu contraseña para ver su seguridad</p>
            </div>
        </div>


        <!-- BOTONES -->
        <div class="flex flex-col-reverse lg:flex-row justify-end gap-2 lg:gap-3 mt-6 lg:mt-8">

            <button id="createUserCancel" type="button" class="px-4 lg:px-5 py-2 border rounded text-sm lg:text-base hover:bg-gray-50 transition">
                Cancelar
            </button>

            <button id="createUserSubmit" type="submit" class="bg-orange-500 text-white px-5 lg:px-6 py-2 rounded hover:bg-orange-600 text-sm lg:text-base font-medium transition">
                Guardar Usuario
            </button>

        </div>
      </form>

        </div>

<%- include('../partials/alertModal') %>
<script>
// Drag and drop - Foto de perfil (INLINE - sin modal)
const profileImageDropZone = document.getElementById('profileImageDropZone');
const profileImageInput = document.getElementById('profileImage');
const profileImagePreview = document.getElementById('profileImagePreview');
const profileImageError = document.getElementById('profileImageError');

if (profileImageDropZone && profileImageInput) {
  const MAX_SIZE = 5 * 1024 * 1024; // 5 MB
  const ALLOWED_TYPES = ['image/jpeg', 'image/png'];

  // Validar archivo
  const validateFile = (file) => {
    profileImageError.style.display = 'none';
    profileImageError.textContent = '';

    if (!file) return false;

    if (!ALLOWED_TYPES.includes(file.type)) {
      profileImageError.textContent = 'Error: Solo JPG, JPEG y PNG están permitidos';
      profileImageError.style.display = 'block';
      return false;
    }

    if (file.size > MAX_SIZE) {
      profileImageError.textContent = `Error: El archivo excede 5 MB (${(file.size / 1024 / 1024).toFixed(2)} MB)`;
      profileImageError.style.display = 'block';
      return false;
    }

    return true;
  };

  // Mostrar preview y guardar archivo
  const handleFile = (file) => {
    if (validateFile(file)) {
      const reader = new FileReader();
      reader.onload = function(event) {
        profileImagePreview.src = event.target.result;
      };
      reader.readAsDataURL(file);
      
      // Guardar archivo en el input
      const dataTransfer = new DataTransfer();
      dataTransfer.items.add(file);
      profileImageInput.files = dataTransfer.files;
    }
  };

  // Click en zona de drop para abrir selector de archivos
  profileImageDropZone.addEventListener('click', () => {
    profileImageInput.click();
  });

  // Cambio de archivo (al seleccionar desde el diálogo)
  profileImageInput.addEventListener('change', function(e) {
    const file = e.target.files[0];
    if (file) {
      handleFile(file);
    }
  });

  // Drag and drop
  profileImageDropZone.addEventListener('dragover', (e) => {
    e.preventDefault();
    profileImageDropZone.classList.add('border-orange-400', 'bg-orange-50');
  });

  profileImageDropZone.addEventListener('dragleave', () => {
    profileImageDropZone.classList.remove('border-orange-400', 'bg-orange-50');
  });

  profileImageDropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    profileImageDropZone.classList.remove('border-orange-400', 'bg-orange-50');
    
    const file = e.dataTransfer.files[0];
    if (file) {
      handleFile(file);
    }
  });
}

const createPhoneInput = document.getElementById('phone');
if (createPhoneInput) {
    const PHONE_PREFIX = '+52 ';
    const formatMxPhone = (digits) => {
        const cleaned = digits.slice(0, 10);
        const part1 = cleaned.slice(0, 3);
        const part2 = cleaned.slice(3, 6);
        const part3 = cleaned.slice(6, 8);
        const part4 = cleaned.slice(8, 10);
        return [part1, part2, part3, part4].filter(Boolean).join(' ');
    };

    const normalizePhone = () => {
        const onlyDigits = createPhoneInput.value.replace(/\D/g, '');
        const nationalDigits = onlyDigits.startsWith('52') ? onlyDigits.slice(2) : onlyDigits;
        createPhoneInput.value = `${PHONE_PREFIX}${formatMxPhone(nationalDigits)}`.trimEnd();
    };

    createPhoneInput.addEventListener('focus', () => {
        if (!createPhoneInput.value) {
            createPhoneInput.value = PHONE_PREFIX;
        }
    });

    createPhoneInput.addEventListener('input', normalizePhone);
    createPhoneInput.addEventListener('keydown', (ev) => {
        const cursor = createPhoneInput.selectionStart || 0;
        if ((ev.key === 'Backspace' || ev.key === 'Delete') && cursor <= PHONE_PREFIX.length) {
            ev.preventDefault();
        }
    });

    normalizePhone();
}

const createBirthDateInput = document.getElementById('birthDate');
if (createBirthDateInput) {
    createBirthDateInput.addEventListener('change', () => {
        const value = createBirthDateInput.value;
        if (!value) return;

        if (value < '1930-01-01') {
            mostrarAlerta('warning', 'Tu no deberias estar vivo');
            createBirthDateInput.value = '';
            return;
        }

        if (value >= '2010-01-01') {
            mostrarAlerta('warning', 'tu no deberias estar aqui, eres viajero del tiempo acaso?');
            createBirthDateInput.value = '';
        }
    });
}

function bindPasswordToggle(inputId, buttonId) {
    const input = document.getElementById(inputId);
    const button = document.getElementById(buttonId);
    const icon = document.getElementById(`${buttonId}Icon`);
    if (!input || !button || !icon) return;

    button.addEventListener('click', () => {
        const isPassword = input.type === 'password';
        input.type = isPassword ? 'text' : 'password';
        icon.classList.toggle('fa-eye');
        icon.classList.toggle('fa-eye-slash');
    });
}

bindPasswordToggle('password', 'toggleCreatePassword');
bindPasswordToggle('confirmPassword', 'toggleConfirmPassword');

// Caps Lock indicator para contraseña
const createPasswordInput = document.getElementById('password');
const createPasswordCapsWarning = document.getElementById('createPasswordCapsWarning');

if (createPasswordInput && createPasswordCapsWarning) {
  createPasswordInput.addEventListener('keydown', (e) => {
    const isCapsLock = e.getModifierState('CapsLock');
    if (isCapsLock) {
      createPasswordCapsWarning.classList.remove('hidden');
    } else {
      createPasswordCapsWarning.classList.add('hidden');
    }
  });

  createPasswordInput.addEventListener('keyup', (e) => {
    const isCapsLock = e.getModifierState('CapsLock');
    if (isCapsLock) {
      createPasswordCapsWarning.classList.remove('hidden');
    } else {
      createPasswordCapsWarning.classList.add('hidden');
    }
  });
}

function updatePasswordRequirements(password) {
    // Validar cada requisito
    const hasMinLength = password.length >= 8;
    const hasUppercase = /[A-Z]/.test(password);
    const hasLowercase = /[a-z]/.test(password);
    const hasNumber = /\d/.test(password);

    // Actualizar indicadores de requisitos
    const reqElements = {
        'reqLength': hasMinLength,
        'reqUppercase': hasUppercase,
        'reqLowercase': hasLowercase,
        'reqNumber': hasNumber
    };

    for (const [id, met] of Object.entries(reqElements)) {
        const element = document.getElementById(id);
        if (element) {
            if (met) {
                element.classList.remove('text-gray-300');
                element.classList.add('text-green-500');
            } else {
                element.classList.remove('text-green-500');
                element.classList.add('text-gray-300');
            }
        }
    }
}

function calculateCreatePasswordStrength(password) {
    // Actualizar requisitos
    updatePasswordRequirements(password);

    // Calcular fortaleza
    const bars = document.querySelectorAll('#createPasswordStrength .h-1');
    const text = document.getElementById('createStrengthText');
    let strength = 0;

    if (password.length >= 8) strength++;
    if (password.length >= 12) strength++;
    if (/[a-z]/.test(password) && /[A-Z]/.test(password)) strength++;
    if (/\d/.test(password)) strength++;

    bars.forEach((bar, index) => {
        if (index < strength) {
            bar.classList.remove('bg-gray-300');
            if (strength <= 2) bar.classList.add('bg-red-500');
            else if (strength === 3) bar.classList.add('bg-yellow-500');
            else bar.classList.add('bg-green-500');
        } else {
            bar.classList.add('bg-gray-300');
            bar.classList.remove('bg-red-500', 'bg-yellow-500', 'bg-green-500');
        }
    });

    if (text) {
        const labels = ['Muy débil', 'Débil', 'Media', 'Fuerte'];
        text.textContent = strength > 0 ? labels[strength - 1] : 'Escribe tu contraseña para ver su fortaleza';
    }
}

if (createPasswordInput) {
    createPasswordInput.addEventListener('input', (ev) => {
        calculateCreatePasswordStrength(ev.target.value);
    });
}
</script>